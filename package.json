{
  "name": "@matheriault/worktree-cli",
  "version": "1.1.4",
  "description": "Interactive CLI for managing git worktrees: list, cd, clean, and bulk-update against master.",
  "keywords": [
    "git",
    "worktree",
    "worktrees",
    "cli",
    "interactive"
  ],
  "type": "module",
  "bin": {
    "wt-cli": "dist/worktree.cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx src/worktree.cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Mathieu Theriault",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattheri/worktree-cli.git"
  },
  "homepage": "https://github.com/mattheri/worktree-cli#readme",
  "bugs": {
    "url": "https://github.com/mattheri/worktree-cli/issues"
  },
  "dependencies": {
    "enquirer": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
